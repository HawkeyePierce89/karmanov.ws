---
/**
 * Stack marquee — an infinite horizontal scroll of the tech stack.
 *
 * Fully presentational and content-driven: the list of technologies comes
 * from `content.stack` in `content.ts`. The track is rendered twice so the
 * `marquee-slide` keyframe (translateX 0 → -50%) loops seamlessly; the second
 * copy is `aria-hidden` so screen readers announce each item only once. Items
 * alternate accent colours for visual rhythm.
 */
import { content } from "../content/content";

// Stack technologies plus the principles/buzzwords (keywords) that used to
// live in the About section.
const items = [...content.stack, ...content.keywords];
// Render the list twice for a seamless -50% loop.
const track = [...items, ...items];
// Keep the visual scroll speed constant regardless of how many words there
// are: ~3.6s of travel per item (matches the original 9-item / 32s feel).
const duration = Math.round(items.length * 3.6);
---

<section class="stack" aria-label="Tech stack">
  <div class="stack__viewport">
    <ul class="stack__track" style={`--marquee-duration: ${duration}s`}>
      {
        track.map((tech, i) => (
          <li
            class={`stack__item ${(i % items.length) % 2 === 0 ? "is-a" : "is-b"}`}
            aria-hidden={i >= items.length ? "true" : undefined}
          >
            {tech}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  // Shuffle the marquee words on every load (Fisher–Yates). We REORDER/CLONE the
  // existing <li> nodes rather than creating new ones, so Astro's scoped styles
  // (the big uppercase / stroke look, applied via a data-astro-cid attribute)
  // are preserved — fresh createElement nodes would miss that attribute and
  // render unstyled. The server-rendered order is the no-JS / SEO fallback.
  const track = document.querySelector(".stack__track");
  if (track) {
    const all = [...track.children];
    const n = all.length / 2; // track is the list rendered twice
    const base = all.slice(0, n);

    for (let i = base.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [base[i], base[j]] = [base[j], base[i]];
    }

    const second = base.map((node) => {
      const clone = node.cloneNode(true) as Element;
      clone.setAttribute("aria-hidden", "true");
      return clone;
    });
    base.forEach((node) => node.removeAttribute("aria-hidden"));

    const ordered = [...base, ...second];
    // Re-alternate the filled / outlined colours by new position.
    ordered.forEach((node, i) => {
      node.classList.remove("is-a", "is-b");
      node.classList.add((i % n) % 2 === 0 ? "is-a" : "is-b");
    });

    track.replaceChildren(...ordered);
  }
</script>

<style>
  .stack {
    padding: clamp(3rem, 9vw, 6rem) 0;
    border-block: 1px solid var(--line);
    overflow: hidden;
  }

  .stack__viewport {
    overflow: hidden;
  }

  .stack__track {
    display: flex;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    margin: 0;
    padding: 0;
    list-style: none;
    width: max-content;
    will-change: transform;
    animation: marquee-slide var(--marquee-duration, 32s) linear infinite;
  }

  .stack__item {
    flex: 0 0 auto;
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .stack__item.is-a {
    color: var(--fg);
  }

  .stack__item.is-b {
    color: transparent;
    -webkit-text-stroke: 1px var(--accent);
  }

  /* Pause the loop when the user prefers reduced motion. */
  @media (prefers-reduced-motion: reduce) {
    .stack__track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      justify-content: center;
    }

    /* The track is rendered twice for the seamless loop; with the animation
       paused and the track wrapping, hide the duplicate copy so reduced-motion
       users don't see every technology listed twice. */
    .stack__item[aria-hidden="true"] {
      display: none;
    }
  }
</style>
