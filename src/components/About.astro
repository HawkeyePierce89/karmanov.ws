---
/**
 * About section — label, lead statement, stats and principle pills.
 *
 * Fully presentational and content-driven: every string comes from
 * `content.about` in `content.ts`. Editing copy or numbers never touches
 * this markup.
 */
import { content } from "../content/content";

const { label, lead, stats } = content.about;
---

<section class="about" id="about">
  <div class="container">
    <p class="label reveal">{label}</p>

    <p class="about__lead reveal">{lead}</p>

    <dl class="about__stats">
      {
        stats.map((stat) => (
          <div class="about__stat reveal">
            <dt class="about__stat-value">{stat.value}</dt>
            <dd class="about__stat-label">{stat.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .about__lead {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
    max-width: 28ch;
    font-size: clamp(1.6rem, 4.2vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.18;
    color: var(--fg);
  }

  /* --- Stats --------------------------------------------------------- */
  .about__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: clamp(1.5rem, 4vw, 3rem);
    margin: clamp(3rem, 8vw, 5rem) 0 0;
    padding: clamp(2rem, 5vw, 3rem) 0 0;
    border-top: 1px solid var(--line);
  }

  .about__stat {
    margin: 0;
  }

  .about__stat-value {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.9;
    background: linear-gradient(120deg, var(--fg) 20%, var(--accent) 70%, var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .about__stat-label {
    margin: 0.7rem 0 0;
    max-width: 18ch;
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.35;
  }
</style>
