---
/**
 * Experience timeline — the four roles, newest first.
 *
 * Fully presentational and content-driven: every entry comes from
 * `content.experience` in `content.ts` (period / company / role / location /
 * summary / bullets). Editing roles or copy never touches this markup.
 */
import { content } from "../content/content";

const { experience } = content;
---

<section class="experience" id="experience">
  <div class="container">
    <p class="label reveal">Experience</p>

    <ol class="experience__list">
      {
        experience.map((entry) => (
          <li class="experience__item reveal">
            <div class="experience__period">{entry.period}</div>

            <div class="experience__body">
              <h3 class="experience__company">{entry.company}</h3>
              <p class="experience__role">
                <span class="experience__role-title">{entry.role}</span>
                <span class="experience__location">{entry.location}</span>
              </p>
              <p class="experience__summary">{entry.summary}</p>
              <ul class="experience__bullets">
                {entry.bullets.map((bullet) => (
                  <li class="experience__bullet">{bullet}</li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .experience__list {
    margin: clamp(2.5rem, 6vw, 4rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .experience__item {
    display: grid;
    grid-template-columns: minmax(8rem, 14rem) 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding: clamp(2rem, 5vw, 3rem) 0;
    border-top: 1px solid var(--line);
  }

  .experience__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .experience__period {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted);
    padding-top: 0.4rem;
  }

  .experience__company {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(120deg, var(--fg) 30%, var(--accent) 90%, var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .experience__role {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    align-items: baseline;
    margin-top: 0.6rem;
  }

  .experience__role-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--fg);
  }

  .experience__location {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .experience__summary {
    margin-top: 0.9rem;
    max-width: 52ch;
    font-size: 1.05rem;
    color: var(--fg);
  }

  .experience__bullets {
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.65rem;
    max-width: 60ch;
  }

  .experience__bullet {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.98rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .experience__bullet::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(120deg, var(--accent), var(--accent-2));
  }

  @media (max-width: 640px) {
    .experience__item {
      grid-template-columns: 1fr;
    }

    .experience__period {
      padding-top: 0;
    }
  }
</style>
